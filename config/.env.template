# Nifty 100 Financial Intelligence Platform — Environment Config
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Database ──────────────────────────────────────────────
DB_PATH=data/nifty100.db

# ── API Server ────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Data Paths ────────────────────────────────────────────
RAW_DATA_DIR=data/raw
SUPPORTING_DATA_DIR=data/supporting
OUTPUT_DIR=output
REPORTS_DIR=reports

# ── Flags ─────────────────────────────────────────────────
# Set to true to show SIMULATED label on stock_prices / market_cap charts
SIMULATED_DATA_FLAG=true

# ── DQ Thresholds ─────────────────────────────────────────
BS_BALANCE_TOLERANCE=0.01
OPM_TOLERANCE=1.0
NET_CASH_TOLERANCE=10
